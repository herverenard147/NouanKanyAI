# Variables d'environnement pour le frontend Next.js
# Copier ce fichier en .env.local et renseigner les vraies valeurs en local.
# En production (Render), ces valeurs sont définies dans le dashboard Render.

# URL du backend FastAPI déployé
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase (clé anonyme publique, sûre à exposer côté client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
