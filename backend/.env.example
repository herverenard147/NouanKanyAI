# Variables d'environnement pour le backend FastAPI
# Copier ce fichier en .env et renseigner les vraies valeurs en local.
# En production (Render), ces valeurs sont définies dans le dashboard Render, jamais committées.

# Clé API Gemini (utilisée pour l'Assistant IA) — https://aistudio.google.com
GEMINI_API_KEY=

# Jeton d'accès personnel Supabase (Management API)
SUPABASE_ACCESS_TOKEN=

# URL et Clé de l'API Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# URL du frontend déployé, pour autoriser le CORS en production
FRONTEND_URL=
