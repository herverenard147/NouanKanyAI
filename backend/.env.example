# Variables d'environnement pour le backend FastAPI
# Copier ce fichier en .env et renseigner les vraies valeurs en local.
# En production (Render), ces valeurs sont définies dans le dashboard Render, jamais committées.

# Clé API Gemini (utilisée pour l'Assistant IA) — https://aistudio.google.com
GEMINI_API_KEY=

# Identifiant de modèle Gemini, épinglé explicitement (défaut ci-dessous). Ne jamais
# revenir à un alias "-latest" : gemini-3.5-flash est le modèle actuellement pointé
# par gemini-flash-latest (source : release notes Google,
# ai.google.dev/gemini-api/docs/changelog). Épingler sur cette version explicite
# neutralise le risque de bascule silencieuse par Google, sans changer le
# comportement du produit en production.
GEMINI_MODEL=gemini-3.5-flash

# "mock" | "live" (défaut si absent : "live"). En mode "mock", les 3 endpoints IA
# (/api/chat, /api/bills/upload-photo, /api/machines/{id}/analyze-media) renvoient
# des réponses simulées sans AUCUN appel réseau à Gemini — recommandé en dev local
# pour préserver le quota gratuit partagé avec la démo. Ne jamais mettre "mock" en
# production (le défaut "live" protège déjà contre un oubli de configuration).
#
# ATTENTION — traçabilité incomplète en mode mock : sur /api/machines/{id}/analyze-media,
# Machine.status peut valoir "alerte" sans marque distinctive (pas de champ dédié sur
# Machine). La seule trace est le [MOCK] dans l'AIAlert liée. Ne jamais exécuter
# AI_MODE=mock contre une base destinée à une démo ou à la production.
AI_MODE=mock

# Plafond du limiteur de débit local vers Gemini (défaut : 10/minute). N'a de sens
# QUE pour un déploiement mono-process (voir GeminiRateLimiter dans main.py) — ce
# plafond est en mémoire, par process, et ne coordonne rien entre plusieurs workers
# ou plusieurs instances.
GEMINI_RATE_LIMIT_PER_MINUTE=10

# Budget d'attente en file (secondes) pour un slot du limiteur ci-dessus, SÉPARÉ du
# timeout réseau de chaque endpoint. Défaut 8s : échouer vite avec un message
# explicite vaut mieux que faire attendre 20-40s (le timeout réseau) pour le même
# message d'échec.
GEMINI_MAX_QUEUE_WAIT=8

# Chaîne de connexion PostgreSQL, ex: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Secret de signature des JWT (générer une chaîne aléatoire longue, ex: `openssl rand -base64 48`)
JWT_SECRET=

# URL du frontend déployé, pour autoriser le CORS en production
FRONTEND_URL=
